# Anthropic — if set, Claude is used. Omit to use Ollama instead.
ANTHROPIC_API_KEY=sk-ant-...

# Ollama — only needed when ANTHROPIC_API_KEY is not set.
OLLAMA_MODEL=gemma4:26b
OLLAMA_BASE_URL=http://localhost:11434

# Tavily — required for web search in the parallelization (sectioning) example.
# Get a free key at https://tavily.com
TAVILY_API_KEY=tvly-...
